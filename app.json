{
  "expo": {
    "name": "tiopet",
    "slug": "tiopet",
    "owner": "charllytwin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tiopet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.charllytwin.tiopet",
      "supportsTablet": true
    },
    "android": {
      "package": "com.charllytwin.tiopet",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "defaultChannel": "tiopet-care-events"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TioPet necesita acceso a tus fotos para adjuntar imagenes locales al timeline de cuidado.",
          "cameraPermission": "TioPet necesita acceso a la camara para tomar fotos locales del timeline de cuidado."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TioPet necesita tu ubicacion mientras el paseo esta activo para guardar la ruta local del cuidado."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
